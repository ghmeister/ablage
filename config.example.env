# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Microsoft Graph — App Registration
TENANT_ID=your_tenant_id
CLIENT_ID=your_app_client_id

# Authentication mode — choose ONE:
#
# Mode A: Personal Microsoft account (free, no M365 license needed)
#   Leave CLIENT_SECRET and USER_ID empty (or remove them).
#   On first run the app will print a URL + code for a one-time login.
#   Tokens are cached in .token_cache.json for all future runs.
#
# Mode B: Work/school account with M365 license (app-only, no login prompt ever)
#   Set CLIENT_SECRET and USER_ID.
#   Requires Files.ReadWrite.All application permission + admin consent in Azure.
#
# CLIENT_SECRET=
# USER_ID=

# OneDrive folder to watch (the "Drop Zone")
# driveItem ID of the folder — find it via Graph Explorer:
#   https://aka.ms/ge
#   GET https://graph.microsoft.com/v1.0/me/drive/root/children
SOURCE_FOLDER_ID=drive_item_id_of_drop_zone

# Optional: Archive root folder path inside OneDrive (e.g., Archive)
# When set, classifier routing will move files into this path.
# OUTPUT_BASE_FOLDER=Archive
# CLASSIFICATION_RULES_FILE=classification_rules.yaml

# Polling interval for Graph delta (seconds)
# POLL_INTERVAL_SECONDS=30

# Optional: Custom prompt for AI naming
# AI_NAMING_PROMPT=Based on the content of this PDF, suggest a concise and descriptive filename (without extension)

# Optional: File naming constraints
# MAX_FILENAME_LENGTH=100
