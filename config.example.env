# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# OneDrive Folder Path to Monitor
# Use absolute path or relative path to the OneDrive folder
ONEDRIVE_FOLDER_PATH=/path/to/your/OneDrive/PDFs

# Optional: Custom prompt for AI naming
# AI_NAMING_PROMPT=Based on the content of this PDF, suggest a concise and descriptive filename (without extension)

# Optional: File naming pattern
# MAX_FILENAME_LENGTH=100
